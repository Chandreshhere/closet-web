{
  "headers": [
    {
      "source": "/(.*)\\.(glb|gltf|bin)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" },
        { "key": "Content-Encoding", "value": "identity" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    }
  ],
  "rewrites": [],
  "cleanUrls": true,
  "trailingSlash": false
}
